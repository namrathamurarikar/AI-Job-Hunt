# career-ops — Environment Variables
# Scripts load .env first (gitignored), then .env.example for any vars still unset.
# Copy to .env and fill real values (never commit .env):
#   cp .env.example .env

# ── Gemini Integration (Issue #344) ─────────────────────────────────────────
# Required for: node gemini-eval.mjs "JD text here"
# Free API key: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional: Override default Gemini model ───────────────────────────────────
# Default: gemini-2.0-flash (free-tier, fast)
# GEMINI_MODEL=gemini-2.0-flash

# ── RapidAPI JSearch (fetch-jobs.mjs) ────────────────────────────────────────
# Subscribe: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# RAPIDAPI_KEY=your_rapidapi_key_here

# ── Ollama (local CV: ollama-cv-pipeline.mjs / dashboard Generate PDF / evaluate fallback) ─
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_TIMEOUT_MS=1800000
# OLLAMA_EVAL_TIMEOUT_MS=1800000
#
# RAM guide (weights on disk ≠ peak RAM: add KV cache + OS; num_ctx raises KV size):
#   llama3.2:1b  — ~1.3 GB pull; often ~3–5 GB system RAM in use (best for ~6 GB total machines)
#   llama3.2:3b  — ~2.0 GB pull; often ~5–8 GB RAM typical (default; good for 8 GB+)
#   llama3.1:8b  — larger than 3.2:3b; needs more headroom (16 GB class), not “smaller than 3b”
# There is no official Llama 3.1 smaller than 3.2 3B — use llama3.2:1b if you need less than 3b.
#
# OLLAMA_MODEL=llama3.2:3b
# OLLAMA_EVAL_MODEL=llama3.2:3b
# Tighter machine: OLLAMA_MODEL=llama3.2:1b
# Heavier / 16 GB+: OLLAMA_MODEL=llama3.1:latest
# OLLAMA_NUM_CTX=4096
# OLLAMA_MAX_NUM_CTX=6144
# OLLAMA_USE_CV_ONLY=1   # Skip merging Ollama summary; entire PDF body from cv.md only

# ── Other integrations (add your own below) ──────────────────────────────────
# ANTHROPIC_API_KEY=your_anthropic_key_here
# OPENAI_API_KEY=your_openai_key_here
